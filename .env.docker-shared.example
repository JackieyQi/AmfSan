# Docker runs only AmfSan; PostgreSQL, Redis, and RabbitMQ are existing shared services.

AMFSAN_HTTP_BIND=0.0.0.0
AMFSAN_HTTP_PORT=8080
AMFSAN_HOST=0.0.0.0
AMFSAN_PORT=8080
AMFSAN_DEBUG=false
AMFSAN_ACCESS_LOG=true
AMFSAN_AUTO_RELOAD=false
AMFSAN_SECRET_KEY=change-this-secret
AMFSAN_ADMINISTRATOR_EMAIL=
AMFSAN_HTTP_INNER_URL=http://127.0.0.1:8080

AMFSAN_DB_ENGINE=postgresql
AMFSAN_DB_HOST=shared-postgres
AMFSAN_DB_PORT=5432
AMFSAN_DB_NAME=amfsan
AMFSAN_DB_USER=amfsan
AMFSAN_DB_PASSWORD=change-this-password
AMFSAN_DB_CHARSET=utf8mb4
AMFSAN_DB_SCHEMA=public
AMFSAN_DB_CONNECTIONS=10
AMFSAN_DB_TIMEOUT=30

AMFSAN_REDIS_HOST=shared-redis
AMFSAN_REDIS_PORT=6379
AMFSAN_REDIS_DB=2

AMFSAN_RABBITMQ_HOST=shared-rabbitmq
AMFSAN_RABBITMQ_PORT=5672
AMFSAN_RABBITMQ_USER=amf
AMFSAN_RABBITMQ_PASSWORD=change-this-password
AMFSAN_RABBITMQ_VHOST=/
AMFSAN_RABBITMQ_EXCHANGE=amf

AMFSAN_EMAIL_SMTP=
AMFSAN_EMAIL_PORT=465
AMFSAN_EMAIL_USER=
AMFSAN_EMAIL_PASSWORD=

AMFSAN_BINANCE_KEY=
AMFSAN_BINANCE_SECRET=
